TIM2.Prescaler=LF_TIMER_PSC
TIM2.Period=LF_TIMER_ARR
TIM2.TIM_MasterOutputTrigger=TIM_TRGO_ENABLE
TIM2.TIM_MasterSlaveMode=TIM_MASTERSLAVEMODE_ENABLE
